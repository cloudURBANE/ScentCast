# =============================================================================
# TEMPLATE ONLY — copied to `.env` for local machines (`.env` is gitignored).
# Production secrets belong in Render + Vercel dashboards, NOT in Git.
# =============================================================================
#
# COMMON MISTAKE
# -------------
# Never paste http://localhost:8080 / 5173 into Render or Vercel Production.
#
# Typical production URLs (substitute yours):
#   API (Render):     https://scentcast.onrender.com           → API_PUBLIC_URL, VITE_* on Vercel
#   Frontend (Vercel): https://scent-cast-explore.vercel.app   → PUBLIC_APP_URL, CORS_ORIGIN on Render
#
# SESSION_SECRET — optional today; reserved if you add cookie sessions later.

SESSION_SECRET=

# -----------------------------------------------------------------------------
# Postgres — required for API startup
#
# Supabase + IPv4: use Transaction/Session pooler URI from Dashboard → Connect.
# Local Docker: pnpm run db:up  → postgresql://scentcast:scentcast@127.0.0.1:5432/scentcast
# Then locally: pnpm run db:push
# -----------------------------------------------------------------------------
DATABASE_URL=

# Local only — if TLS chain errors (often antivirus inspection). Omit on Render.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# -----------------------------------------------------------------------------
# LOCAL development — API + OAuth (see DEPLOY.txt for Google Console redirect URIs)
# -----------------------------------------------------------------------------
#
# Where Vite proxies /api when you run `pnpm run dev:web` (defaults work if omitted):
# VITE_DEV_API_PROXY=http://127.0.0.1:8080
#
# Backend origin OAuth uses for redirect_uri. Local MUST be the API origin, not Vite’s port:
#   API_PUBLIC_URL=http://localhost:8080
#
# Local UI origin (CORS): use localhost — NOT your Vercel URL while developing locally.
#   PUBLIC_APP_URL=http://localhost:5173
#   CORS_ORIGIN=http://localhost:5173
#
# For same-machine dev you often omit VITE_API_ORIGIN (Vite proxies /api).

# -----------------------------------------------------------------------------
# SPLIT DEPLOYMENT (Production) — set these ON THE HOSTING DASHBOARD, not in Git
#
# Render (API service):
#   API_PUBLIC_URL    = https://YOUR-API.onrender.com     (origin only, no path)
#   PUBLIC_APP_URL    = https://YOUR-APP.vercel.app
#   CORS_ORIGIN       = https://YOUR-APP.vercel.app
#   DATABASE_URL, GOOGLE_CLIENT_*, etc.
#
# Vercel (frontend) — bake at build → redeploy after change:
#   VITE_API_ORIGIN = same origin as API_PUBLIC_URL (e.g. https://YOUR-API.onrender.com)
# -------------------------------------------------------------------------------

API_PUBLIC_URL=
VITE_API_ORIGIN=
VITE_OAUTH_ORIGIN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

PUBLIC_APP_URL=
CORS_ORIGIN=

# Gemini (Replit-style integration URLs; use your provider’s values outside Replit)
AI_INTEGRATIONS_GEMINI_BASE_URL=
AI_INTEGRATIONS_GEMINI_API_KEY=

# Optional features
WEATHER_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
REMOVE_BG_API_KEY=

# Firebase Admin — optional bg_cache only; wardrobe/users are Postgres.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Server (Render sets PORT automatically — do not duplicate unless you know why)
# PORT=10000
# HOST=0.0.0.0
