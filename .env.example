# Copy to .env locally (see .gitignore); on Render/Vercel set these in the dashboard.
# SESSION_SECRET — optional today; reserved if you add cookie sessions later.

SESSION_SECRET=

# PostgreSQL — required for API startup
#
# Supabase + IPv4 / “Not IPv4 compatible” warning:
#   Use the pooler: same db.*.supabase.co host but port 6543 (Transaction pooler), or copy the full “Session pooler” URI from Dashboard → Connect (user looks like postgres.[project-ref] @ aws-0-REGION.pooler.supabase.com:5432).
#
# Fastest on Windows (no Docker): Neon or Supabase → connection string + sslmode=require.
# Then: pnpm run db:push
#
# Local Docker (often slow to start on Windows): pnpm run db:up
#   postgresql://scentcast:scentcast@127.0.0.1:5432/scentcast
DATABASE_URL=

# Only if db:push / API fails with SELF_SIGNED_CERT_IN_CHAIN (often antivirus TLS inspection). Do not use on public servers.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional: where Vite proxies /api in dev (default http://127.0.0.1:8080)
# VITE_DEV_API_PROXY=http://127.0.0.1:8080

# Backend URL used for OAuth redirect_uri (must match Google Cloud → Authorized redirect URIs exactly).
# Local: http://localhost:8080  → redirect URI http://localhost:8080/api/auth/google/callback
# Prod:  https://your-api.onrender.com
API_PUBLIC_URL=

# Vite exposes this to the browser so “Sign in with Google” loads /api/auth on port 8080 (not Vite’s 5173).
# Locally should match API_PUBLIC_URL. Production: same as API_PUBLIC_URL (build-time on Vercel).
# VITE_OAUTH_ORIGIN=http://localhost:8080

# Google OAuth — Web client → Authorized JavaScript origins: http://localhost:5173 (and prod UI URL).
# Authorized redirect URIs: {API_PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Split deploy: your Vercel app URL (OAuth return + CORS)
PUBLIC_APP_URL=https://scent-cast-explore.vercel.app
CORS_ORIGIN=https://scent-cast-explore.vercel.app

# Gemini (Replit-style integration URLs; use your provider’s values outside Replit)
AI_INTEGRATIONS_GEMINI_BASE_URL=
AI_INTEGRATIONS_GEMINI_API_KEY=

# Optional features
WEATHER_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
REMOVE_BG_API_KEY=

# Firebase Admin (Firestore) — optional; used only for the bg_remove image cache collection "bg_cache".
# This is NOT where app users/wardrobe live; those are in PostgreSQL (DATABASE_URL above).
# If you have a service account JSON from Firebase Console (Project settings → Service accounts):
#   FIREBASE_PROJECT_ID   ← "project_id"
#   FIREBASE_CLIENT_EMAIL ← "client_email"
#   FIREBASE_PRIVATE_KEY  ← "private_key" (paste as one line; keep \n for newlines, e.g. -----BEGIN PRIVATE KEY-----\nMII...)
# On Vercel/Render: add these three as separate env vars; redeploy the API after saving.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Server (Render sets PORT automatically)
# PORT=10000
# HOST=0.0.0.0
